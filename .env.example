# Cloudflare Turnstile — pobierz klucze z https://dash.cloudflare.com → Turnstile
# VITE_ prefix = widoczne w przeglądarce (site key)
VITE_TURNSTILE_SITE_KEY=your_site_key_here
# Bez VITE_ = tylko serwer (secret key)
TURNSTILE_SECRET_KEY=your_secret_key_here

# GUS BIR 1.1 — klucz do wyszukiwania firm po NIP/REGON (rejestr REGON)
# Klucz testowy: abcde12345abcde12345 | Produkcyjny: https://api.stat.gov.pl/Home/RegonApi
GUS_API_KEY=your_gus_api_key_here
